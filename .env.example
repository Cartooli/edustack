# =============================================================================
# EduStack Environment Variables
# =============================================================================
#
# HOW TO USE:
# 1. Copy this file to .env:        cp .env.example .env
# 2. Fill in your API key below
# 3. NEVER commit the .env file (it's in .gitignore for protection)
#
# WHO SETS THIS UP:
# Your school's IT department should configure the API key.
# Students should NEVER see or handle API keys.
#
# The .env file is listed in .gitignore — it will NOT be pushed to GitHub.
# =============================================================================

# Anthropic API Key — required for AI tutor features
# Get this from your school's IT department
# Format: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-your-key-here
